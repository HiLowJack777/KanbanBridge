{
  "name": "kanban-bridge",
  "version": "0.1.0",
  "private": true,
  "productName": "KanbanBridge",
  "description": "Offline-first Kanban board with a local agent connector.",
  "license": "MIT",
  "main": "dist/electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:main\" \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 dist/electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "start": "electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "agent": "node scripts/agent-bridge.mjs",
    "agent:observe": "node scripts/agent-bridge.mjs observe",
    "agent:list": "node scripts/agent-bridge.mjs list",
    "agent:snapshot": "node scripts/agent-bridge.mjs snapshot",
    "agent:card": "node scripts/agent-bridge.mjs card",
    "agent:card:update": "node scripts/agent-bridge.mjs update-card",
    "agent:card:move": "node scripts/agent-bridge.mjs move-card",
    "agent:card:archive": "node scripts/agent-bridge.mjs archive-card",
    "agent:card:tag": "node scripts/agent-bridge.mjs tag-card",
    "agent:card:untag": "node scripts/agent-bridge.mjs untag-card",
    "agent:checklist": "node scripts/agent-bridge.mjs checklist",
    "agent:observation:link": "node scripts/agent-bridge.mjs link-observation",
    "agent:observation:unlink": "node scripts/agent-bridge.mjs unlink-observation",
    "agent:archive": "node scripts/agent-bridge.mjs archive",
    "package:dir": "pnpm build && electron-builder --dir --win --x64",
    "package:win": "pnpm build && electron-builder --win --x64",
    "shortcut:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-desktop-shortcut.ps1",
    "install:desktop": "pnpm package:dir && pnpm shortcut:desktop"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.local.kanbanbridge",
    "productName": "KanbanBridge",
    "asar": false,
    "directories": {
      "output": "desktop-release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KanbanBridge"
    }
  }
}
